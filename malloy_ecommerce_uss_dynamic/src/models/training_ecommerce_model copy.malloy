  --   --   inventory_items.product_distribution_center_id
  --   -- )
  --   _key_distribution_centers is coalesce(
  --     --order_items.products.distribution_center_id,
  --     --products.distribution_center_id,
  --     inventory_items.product_distribution_center_id
  --   )

  --   _key_events is events.event_id,

  --   _key_event_session_facts is coalesce(
