source: users is bigquery.table('bigquery-public-data.thelook_ecommerce.users') extend {
  primary_key: user_id
  dimension: user_id is id

  measure: user_count is count()

  view: detail is {
    select: 
      user_id, 
      last_name, 
      first_name, 
      city, 
      state, 
      country
  }
}